class FoodQualityPipeline:
    def __init__(self, vlm: BaseVLM):
        self.vlm = vlm
        self.contradictions = []

    def evaluate(self, image_path: str, checks: list = None) -> dict:
        """Evaluate food quality by running all checks"""
        image = Image.open(image_path).convert("RGB")
        checks = checks or list(PROMPTS.keys())
        results = {}
        for check in checks:
            prompt = PROMPTS[check]
            results[check] = self.vlm.predict(image, prompt)
        return results

    def parse_result(self, check_name: str, response: str) -> dict:
        """Parse VLM response and extract key information"""
        lines = response.strip().split('\n')
        parsed = {'check': check_name, 'raw_response': response}
        
        for line in lines:
            if ':' in line:
                key, value = line.split(':', 1)
                parsed[key.strip().lower()] = value.strip()
        
        return parsed

    def validate_consistency(self, parsed_results: list) -> tuple:
        """
        Check for contradictions in VLM responses.
        Returns: (is_consistent, list_of_contradictions)
        """
        contradictions = []
        
        oil_check = next((p for p in parsed_results if p['check'] == 'oil_colour_check'), None)
        sop_check = next((p for p in parsed_results if p['check'] == 'sop_compliance'), None)
        garnish_check = next((p for p in parsed_results if p['check'] == 'garnishing_check'), None)
        
        # Contradiction 1: Oil level contradiction
        if oil_check and sop_check:
            oil_result = oil_check.get('result', '').lower()
            sop_oil = sop_check.get('oil', '').lower()
            oil_level = oil_check.get('oil_level', '').lower()
            
            if ('not good' in oil_result or 'excessive' in oil_level) and 'pass' in sop_oil:
                contradictions.append({
                    'type': 'Oil Level Contradiction',
                    'detail': f'Oil check says "{oil_check.get("result")}" but SOP says Oil: Pass',
                    'decision': 'OVERRIDE TO FAIL (trust oil_colour_check)'
                })
        
        # Contradiction 2: Garnishing contradiction
        if garnish_check and sop_check:
            garnish_result = garnish_check.get('garnishing', '').lower()
            sop_garnish = sop_check.get('garnishing', '').lower()
            
            if 'absent' in garnish_result and 'pass' in sop_garnish:
                contradictions.append({
                    'type': 'Garnishing Contradiction',
                    'detail': f'Garnishing check says "Absent" but SOP says Garnishing: Pass',
                    'decision': 'OVERRIDE TO FAIL (garnishing is mandatory)'
                })
        
        return len(contradictions) == 0, contradictions

    def is_quality_good(self, parsed_results: list) -> bool:
        """
        Determine overall quality with strict contradiction handling
        """
        # Check for contradictions
        is_consistent, contradictions = self.validate_consistency(parsed_results)
        self.contradictions = contradictions
        
        # If contradictions found, use STRICT logic
        if contradictions:
            # Fail if ANY critical check fails
            for result in parsed_results:
                check = result.get('check', '')
                
                # Critical checks that cause immediate failure
                if check in ['oil_colour_check', 'garnishing_check']:
                    if 'not good' in result.get('result', '').lower() or \
                       'fail' in result.get('result', '').lower():
                        return False
                
                if check == 'sop_compliance':
                    if 'rejected' in result.get('overall', '').lower():
                        return False
        
        # Standard logic if no contradictions
        else:
            critical_checks = {
                'cooking_quality': ['good'],
                'oil_colour_check': ['good'],
                'sop_compliance': ['approved']
            }
            
            for result in parsed_results:
                check = result.get('check', '')
                if check in critical_checks:
                    found_acceptable = False
                    for acceptable_value in critical_checks[check]:
                        if acceptable_value.lower() in result.get('result', '').lower():
                            found_acceptable = True
                            break
                    if not found_acceptable:
                        return False
        
        return True

    def format_output(self, results: dict) -> None:
        """Format and display results in a structured way"""
        parsed_results = []
        for check, response in results.items():
            parsed = self.parse_result(check, response)
            parsed_results.append(parsed)
        
        is_good = self.is_quality_good(parsed_results)
        
        print("\n" + "=" * 80)
        print("🍽️  FOOD QUALITY ASSESSMENT REPORT")
        print("=" * 80)
        
        # Show contradictions if found
        if self.contradictions:
            print("\n⚠️  CONTRADICTION DETECTION SYSTEM ACTIVATED")
            for i, contradiction in enumerate(self.contradictions, 1):
                print(f"\n{i}. {contradiction['type']}")
                print(f"   Issue: {contradiction['detail']}")
                print(f"   Action: {contradiction['decision']}")
        
        # Overall Status
        if is_good:
            print("\n✅ OVERALL STATUS: APPROVED - EXCELLENT QUALITY!")
            self._print_approval_message(parsed_results)
        else:
            print("\n❌ OVERALL STATUS: NEEDS IMPROVEMENT")
            self._print_detailed_issues(parsed_results)
        
        # Detailed Breakdown
        print("\n" + "-" * 80)
        print("📋 DETAILED ASSESSMENT")
        print("-" * 80)
        self._print_detailed_breakdown(parsed_results, is_good)
        
        print("\n" + "=" * 80)

    def _print_approval_message(self, parsed_results: list) -> None:
        """Print short encouraging message when food is good"""
        print("\n🎉 CHEF'S KUDOS:")
        print("   Outstanding work! The food looks delicious, well-prepared, and")
        print("   meets all quality standards. Keep maintaining this consistency!")
        print("   Your attention to detail and cooking skill is commendable. 👨‍🍳")

    def _print_detailed_issues(self, parsed_results: list) -> None:
        """Print detailed issues when food quality is not good"""
        print("\n⚠️  CRITICAL ISSUES FOUND:")
        
        for parsed in parsed_results:
            check = parsed.get('check', '')
            result = parsed.get('result', '').lower()
            
            if check == 'oil_colour_check':
                if 'not good' in result:
                    oil = parsed.get('oil_level', 'Unknown')
                    color = parsed.get('colour', 'Unknown')
                    reason = parsed.get('reason', '')
                    print(f"\n  🎨 Oil & Colour Issue:")
                    print(f"     Oil Level: {oil}")
                    print(f"     Colour: {color}")
                    print(f"     Details: {reason}")
            
            elif check == 'garnishing_check':
                if 'fail' in result:
                    garnish = parsed.get('garnishing', 'Unknown')
                    plating = parsed.get('plating', 'Unknown')
                    print(f"\n  ✨ Presentation Issue:")
                    print(f"     Garnishing: {garnish}")
                    print(f"     Plating: {plating}")
            
            elif check == 'salad_check':
                missing = parsed.get('missing', 'Unknown')
                if missing and 'not' not in missing.lower():
                    print(f"\n  🥗 Salad Incomplete:")
                    print(f"     Missing Items: {missing}")

    def _print_detailed_breakdown(self, parsed_results: list, is_good: bool) -> None:
        """Print detailed breakdown of each check"""
        
        check_display_names = {
            'cooking_quality': '🍚 Cooking Quality',
            'veg_nonveg': '🥕 Veg/Non-Veg Classification',
            'jain_check': '☮️  Jain Compliance',
            'oil_colour_check': '🎨 Oil Level & Colour',
            'salad_check': '🥗 Salad Completeness',
            'garnishing_check': '✨ Garnishing & Plating',
            'sop_compliance': '✅ SOP Compliance'
        }
        
        for parsed in parsed_results:
            check = parsed.get('check', '')
            display_name = check_display_names.get(check, check.upper())
            
            print(f"\n{display_name}")
            print("─" * 80)
            
            if is_good:
                result = parsed.get('result', 'N/A')
                print(f"Status: ✅ {result}")
            else:
                for key, value in parsed.items():
                    if key not in ['check', 'raw_response']:
                        if value:
                            print(f"  {key.replace('_', ' ').title()}: {value}")


